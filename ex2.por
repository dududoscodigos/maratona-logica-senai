programa {
  funcao inicio() {

		inteiro remessa1, remessa2, estoque_total


		escreva("Digite a quantidade da primeira remessa: ")
  	leia(remessa1)
		escreva("Digite a quantidade da segunda remessa: ")
		leia(remessa2)


		estoque_total = remessa1 + remessa2


		escreva("Estoque total disponível: ", estoque_total, " parafusos.\n")
  }
}
